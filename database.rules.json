{
  "rules": {
    "chats": {
      "$chatId": {
        ".read": "auth != null && $chatId.contains(auth.uid)",
        ".write": "auth != null && $chatId.contains(auth.uid)",
        "messages": {
          "$messageId": {
            ".validate": "newData.hasChildren(['senderId', 'text', 'timestamp'])"
          }
        },
        "metadata": {
          ".validate": true
        },
        "typing": {
          "$uid": {
            ".validate": true
          }
        }
      }
    },
    "presence": {
      "$uid": {
        ".read": "auth != null",
        ".write": "auth != null && auth.uid == $uid"
      }
    },
    "linkHistory": {
      "$uid": {
        ".read": "auth != null && auth.uid == $uid",
        ".write": "auth != null && auth.uid == $uid"
      }
    },
    "$other": {
      ".read": false,
      ".write": false
    }
  }
}
