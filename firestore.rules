rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Auth helpers ──────────────────────────────────────────────────────────
    function isSignedIn() { return request.auth != null; }
    
    function isAdmin() {
      return isSignedIn() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // ── Users collection ──────────────────────────────────────────────────────
    match /users/{uid} {
      // Any authenticated user can read user docs (team management, assignment).
      allow read: if isSignedIn();
      // Users can register/create their own doc during auth, and Admins can update docs.
      allow create: if isSignedIn();
      allow update: if isSignedIn() && (request.auth.uid == uid || isAdmin());
      // Only Admins can delete users.
      allow delete: if isSignedIn() && isAdmin();

      // Notifications sub-collection
      match /notifications/{notifId} {
        allow read, write: if isSignedIn();
      }

      // Sessions sub-collection (Admins need to write to terminate sessions)
      match /sessions/{sessionId} {
        allow read, write: if isSignedIn();
      }
    }

    // ── Invites ───────────────────────────────────────────────────────────────
    match /invites/{inviteId} {
      // Anyone can read (needed before login to validate invite link)
      allow read:   if true;
      // Only Admins can generate invites
      allow write:  if isSignedIn() && isAdmin();
    }

    // ── Tasks ─────────────────────────────────────────────────────────────────
    match /tasks/{taskId} {
      allow read: if isSignedIn();
      // Only Admins can create and delete tasks
      allow create, delete: if isSignedIn() && isAdmin();
      // Any authenticated user can update task status/notes
      allow update: if isSignedIn();
    }

    // ── Channels ──────────────────────────────────────────────────────────────
    match /channels/{channelId} {
      allow read:   if isSignedIn();
      allow write:  if isSignedIn() && isAdmin();
    }

    // ── Payments ──────────────────────────────────────────────────────────────
    match /payments/{paymentId} {
      allow read:   if isSignedIn();
      allow create, update, delete: if isSignedIn() && isAdmin();
    }

    // ── Audit Logs ────────────────────────────────────────────────────────────
    match /audit_logs/{logId} {
      allow read:   if isSignedIn();
      allow create: if isSignedIn();
      allow update, delete: if false;
    }

    // ── AI Analysis Logs ──────────────────────────────────────────────────────
    match /ai_analysis_logs/{logId} {
      allow read:   if isSignedIn();
      allow create: if isSignedIn();
      allow update, delete: if false;
    }

    // ── Fallback ──────────────────────────────────────────────────────────────
    match /{document=**} {
      allow read, write: if isSignedIn() && isAdmin();
    }
  }
}
