rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Simple auth check ─────────────────────────────────────────────────────
    // We avoid nested get() calls inside rules entirely.
    // Role-based filtering is enforced client-side in the application code.
    // The rules ensure only authenticated users access the database and that
    // users cannot read/write data belonging to other users where applicable.
    function isSignedIn() { return request.auth != null; }

    // ── Users collection ──────────────────────────────────────────────────────
    match /users/{uid} {
      // Any authenticated user can read user docs (team management, assignment).
      allow read: if isSignedIn();
      // Users can create/update their own doc only.
      allow create, update: if isSignedIn() && request.auth.uid == uid;
      // Admins need to delete other users — admin check enforced in app code.
      allow delete: if isSignedIn();

      // Notifications sub-collection — owner + any authenticated user can delete
      match /notifications/{notifId} {
        allow read, write: if isSignedIn() && request.auth.uid == uid;
        allow delete: if isSignedIn();
      }

      // Sessions sub-collection — owner + any authenticated user can delete
      match /sessions/{sessionId} {
        allow read, write: if isSignedIn() && request.auth.uid == uid;
        allow delete: if isSignedIn();
      }
    }

    // ── Invites ───────────────────────────────────────────────────────────────
    match /invites/{inviteId} {
      // Anyone can read (needed before login to validate invite link)
      allow read:   if true;
      // Any authenticated user can write (create invite or mark as used)
      allow write:  if isSignedIn();
    }

    // ── Tasks ─────────────────────────────────────────────────────────────────
    match /tasks/{taskId} {
      // All authenticated users can read tasks.
      // Client-side code filters by role (editors only see their tasks).
      allow read: if isSignedIn();

      // Only allow creates/deletes from authenticated users.
      // Admin enforcement is done at the application layer.
      allow create: if isSignedIn();
      allow delete: if isSignedIn();

      // Any authenticated user can update a task (role checks in app code).
      allow update: if isSignedIn();
    }

    // ── Channels ──────────────────────────────────────────────────────────────
    match /channels/{channelId} {
      allow read:   if isSignedIn();
      allow write:  if isSignedIn();
    }

    // ── Payments ──────────────────────────────────────────────────────────────
    match /payments/{paymentId} {
      allow read:   if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn();
      allow delete: if false;
    }

    // ── Audit Logs ────────────────────────────────────────────────────────────
    match /audit_logs/{logId} {
      allow read:   if isSignedIn();
      allow create: if isSignedIn();
      allow update, delete: if false;
    }

    // ── AI Analysis Logs ──────────────────────────────────────────────────────
    match /ai_analysis_logs/{logId} {
      allow read:   if isSignedIn();
      allow create: if isSignedIn();
      allow update, delete: if false;
    }

    // ── Deny everything else ──────────────────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
